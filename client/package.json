{
  "name": "client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "concurrently -k -n mock,client -c yellow,cyan \"npm run mock\" \"cross-env VITE_PROXY_TARGET=http://localhost:3000 npm run dev\"",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "check": "run-s gen:mock-api:check \"check:*\"",
    "gen:mock-api": "openapi-typescript docs/mock-openapi.yaml -o src/api/schema.d.ts && oxfmt src/api/schema.d.ts",
    "gen:mock-api:check": "npm run gen:mock-api && git diff --exit-code -- src/api/schema.d.ts",
    "mock": "tsx mock/server.ts",
    "check:format": "npm run format:check",
    "check:lint": "npm run lint:check",
    "check:type": "run-p type-check type-check:mock",
    "type-check": "vue-tsc --build",
    "type-check:mock": "tsc -p tsconfig.mock.json --noEmit",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint:check": "run-p lint:oxlint:check lint:eslint:check",
    "lint:oxlint": "oxlint . --fix",
    "lint:oxlint:check": "oxlint . --deny-warnings",
    "lint:eslint": "eslint . --fix --cache",
    "lint:eslint:check": "eslint . --max-warnings=0",
    "format": "oxfmt src/",
    "format:check": "oxfmt src/ --check"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-vue": "~10.9.2",
    "express": "^5.2.1",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.54.0",
    "oxlint": "~1.69.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.22.4",
    "typescript": "~5.9.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "8.1.2",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.22.2 || >=24.15.0"
  },
  "overrides": {
    "@vue/devtools-api": "8.1.2",
    "@vue/devtools-core": "8.1.2",
    "@vue/devtools-kit": "8.1.2",
    "@vue/devtools-shared": "8.1.2"
  }
}
